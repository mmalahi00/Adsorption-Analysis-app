    "created": "2026-01-17",
    "last_updated": "2026-03-10",
    "note": "Parameters verified by running _fit_all_isotherm_models_cached and _fit_all_kinetic_models_cached on isotherm_direct.csv and kinetic_direct.csv (Python 3.12, scipy 1.13).",
    "tolerance": {
      "parameter_relative": 0.10,
      "r_squared_absolute": 0.01
    }
  },

  "calibration_data": {
    "file": "calibration_data.csv",
    "expected_results": {
      "slope": {
        "value": 0.01666,
        "unit": "L/mg",
        "tolerance": 0.001
      },
      "intercept": {
        "value": 0.002,
        "unit": "AU",
        "tolerance": 0.005
      },
      "r_squared": {
        "value": 0.9999,
        "min_acceptable": 0.995
      },
      "concentration_range": {
        "min": 0,
        "max": 100,
        "unit": "mg/L"
      }
    }
  },

  "isotherm_data": {
    "file": "isotherm_data.csv",
