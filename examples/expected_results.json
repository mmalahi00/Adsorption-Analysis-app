      "langmuir": {
        "qm_mg_g": { "value": 64.6, "unit": "mg/g", "tolerance": 5.0 },
        "KL_L_mg": { "value": 0.023, "unit": "L/mg", "tolerance": 0.005 },
        "r_squared": { "value": 0.993, "min_acceptable": 0.98 },
        "RL_range": { "min": 0.12, "max": 0.82, "interpretation": "favorable" }
      },
      "freundlich": {
        "KF_mg_g": { "value": 5.2, "unit": "(mg/g)(L/mg)^(1/n)", "tolerance": 1.5 },
        "n": { "value": 2.2, "unit": "dimensionless", "tolerance": 0.3 },
        "r_squared": { "value": 0.988, "min_acceptable": 0.95 },
        "interpretation": "favorable (n > 1)"
      },
      "temkin": {
        "_note": "Temkin may not converge for wide-range (C0 10-300 mg/L) datasets because the logarithmic model poorly fits high-concentration saturation regions. This is expected and correct behaviour.",
