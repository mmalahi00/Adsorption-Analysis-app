        "ns": { "value": 0.74, "unit": "dimensionless", "tolerance": 0.15 },
        "r_squared": { "value": 0.999, "min_acceptable": 0.98 }
      },
      "best_model": "sips",
      "selection_criterion": "AIC"
    }
  },

